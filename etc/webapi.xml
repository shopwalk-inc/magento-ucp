<?xml version="1.0"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">

    <!-- Discovery (public) -->
    <route url="/V1/shopwalk/ucp/discovery" method="GET">
        <service class="Shopwalk\Ucp\Api\DiscoveryInterface" method="getDiscovery"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <!-- Checkout Sessions -->
    <route url="/V1/shopwalk/ucp/checkout-sessions" method="POST">
        <service class="Shopwalk\Ucp\Api\CheckoutSessionInterface" method="create"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <route url="/V1/shopwalk/ucp/checkout-sessions/:id" method="GET">
        <service class="Shopwalk\Ucp\Api\CheckoutSessionInterface" method="get"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <route url="/V1/shopwalk/ucp/checkout-sessions/:id" method="PUT">
        <service class="Shopwalk\Ucp\Api\CheckoutSessionInterface" method="update"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <route url="/V1/shopwalk/ucp/checkout-sessions/:id/complete" method="POST">
        <service class="Shopwalk\Ucp\Api\CheckoutSessionInterface" method="complete"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <route url="/V1/shopwalk/ucp/checkout-sessions/:id/cancel" method="POST">
        <service class="Shopwalk\Ucp\Api\CheckoutSessionInterface" method="cancel"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <!-- Orders -->
    <route url="/V1/shopwalk/ucp/orders" method="GET">
        <service class="Shopwalk\Ucp\Api\OrderInterface" method="getList"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <route url="/V1/shopwalk/ucp/orders/:id" method="GET">
        <service class="Shopwalk\Ucp\Api\OrderInterface" method="get"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <route url="/V1/shopwalk/ucp/orders/:id/events" method="GET">
        <service class="Shopwalk\Ucp\Api\OrderInterface" method="getEvents"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <!-- Store (public) -->
    <route url="/V1/shopwalk/ucp/store" method="GET">
        <service class="Shopwalk\Ucp\Api\StoreInterface" method="getStore"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <!-- Products (public) -->
    <route url="/V1/shopwalk/ucp/products" method="GET">
        <service class="Shopwalk\Ucp\Api\ProductInterface" method="getList"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <!-- Direct Checkout -->
    <route url="/V1/shopwalk/ucp/checkout" method="POST">
        <service class="Shopwalk\Ucp\Api\DirectCheckoutInterface" method="create"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <!-- OAuth (token is public, revoke is authenticated) -->
    <route url="/V1/shopwalk/ucp/oauth/token" method="POST">
        <service class="Shopwalk\Ucp\Api\OAuthInterface" method="token"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>

    <route url="/V1/shopwalk/ucp/oauth/revoke" method="POST">
        <service class="Shopwalk\Ucp\Api\OAuthInterface" method="revoke"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <!-- Webhooks -->
    <route url="/V1/shopwalk/ucp/webhooks/subscriptions" method="POST">
        <service class="Shopwalk\Ucp\Api\WebhookInterface" method="create"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <route url="/V1/shopwalk/ucp/webhooks/subscriptions/:id" method="GET">
        <service class="Shopwalk\Ucp\Api\WebhookInterface" method="get"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

    <route url="/V1/shopwalk/ucp/webhooks/subscriptions/:id" method="DELETE">
        <service class="Shopwalk\Ucp\Api\WebhookInterface" method="delete"/>
        <resources>
            <resource ref="Shopwalk_Ucp::manage"/>
        </resources>
    </route>

</routes>
